# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key (alternative to Claude)
GOOGLE_API_KEY=your_gemini_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────
# Set to "gemini" to use Google Gemini, "claude" to use Anthropic Claude
LLM_PROVIDER=gemini

# ── Model names ────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514
# Free Gemini options: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── Generation settings ────────────────────────────────────────────
MAX_TOKENS=2048
TEMPERATURE=0.1

# ── Retrieval settings ─────────────────────────────────────────────
TOP_K_RETRIEVAL=6
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Paths ──────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
EMBEDDINGS_DIR=embeddings

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
